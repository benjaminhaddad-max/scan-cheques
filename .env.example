# =====================================================================
# Cheques Standalone — variables d'environnement
# Copier ce fichier vers .env (local) et remplir les valeurs.
# Sur Vercel : Project Settings → Environment Variables.
# =====================================================================

# --- Base de données Postgres (Neon recommandé) ---
# Format : postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Récupérer sur https://console.neon.tech → Connection Details (Pooled)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- Stockage des images de chèques (Vercel Blob) ---
# Récupérer sur https://vercel.com/dashboard/stores → Create Blob Store
# → onglet .env.local → copier la ligne BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx_yyyyyyyy"

# --- OpenAI (OCR via GPT-5 vision) ---
# Récupérer sur https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxx"

# --- Supabase Auth ---
# Récupérer sur https://supabase.com → ton projet → Project Settings → API
# Tant que ces 2 variables ne sont pas définies, l'auth est désactivée
# (toutes les routes API restent publiques — utile pour un déploiement de test).
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR..."
