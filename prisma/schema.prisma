generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Stockage d'un upload de chèque (image ou page extraite d'un ZIP)
// + métadonnées d'OCR (statut, texte brut, JSON parsé, score de confiance)
model OcrUpload {
  id          String    @id @default(cuid())
  blobUrl     String
  fileName    String
  sizeBytes   Int
  status      String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  model       String?
  attempts    Int       @default(0)
  error       String?
  rawText     String?
  parsedJson  Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  confidence  Int?
  folderId    String?
  folderName  String?
  folderOrder Int?

  @@map("ocr_uploads")
}
